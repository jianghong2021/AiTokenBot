<Window x:Class="AiTokenBot.Views.ImportWalletDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="520" Height="420">
    <Window.Style>
        <Style TargetType="Window" BasedOn="{StaticResource {x:Type Window}}"/>
    </Window.Style>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="导入钱包" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"
                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>

        <!-- Tab Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button x:Name="BtnPrivateKey" Content="私钥" Width="90" Height="32" FontSize="13"
                    Click="OnSwitchPrivateKey"/>
            <Button x:Name="BtnMnemonic" Content="助记词" Width="90" Height="32" FontSize="13" Margin="8,0,0,0"
                    Click="OnSwitchMnemonic"/>
        </StackPanel>

        <!-- Private Key Panel -->
        <StackPanel Grid.Row="2" x:Name="PanelPrivateKey" Visibility="Visible">
            <TextBlock Text="钱包名称" FontSize="13" Margin="0,0,0,4"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <TextBox x:Name="TbPkName" Height="36"
                     Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                     Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                     BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                     Text="我的钱包"/>

            <TextBlock Text="私钥 (Base58) 或 JSON Keypair" FontSize="13" Margin="0,16,0,4"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <PasswordBox x:Name="TbPrivateKey" Height="36"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>

            <TextBlock Text="私钥仅在本地存储，不会上传到任何服务器" FontSize="11" Opacity="0.4" Margin="0,8,0,0"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
        </StackPanel>

        <!-- Mnemonic Panel -->
        <StackPanel Grid.Row="2" x:Name="PanelMnemonic" Visibility="Collapsed">
            <TextBlock Text="钱包名称" FontSize="13" Margin="0,0,0,4"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <TextBox x:Name="TbMnName" Height="36"
                     Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                     Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                     BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                     Text="我的钱包"/>

            <TextBlock Text="助记词 (12 或 24 个单词)" FontSize="13" Margin="0,16,0,4"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <TextBox x:Name="TbMnemonic" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                     Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                     BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                     Text=""/>

            <TextBlock Text="请按空格分隔单词，助记词仅在本地存储" FontSize="11" Opacity="0.4" Margin="0,8,0,0"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Width="90" Height="38" Click="OnCancelClick"/>
            <Button Content="导入" Width="90" Height="38" Margin="12,0,0,0" Click="OnImportClick"/>
        </StackPanel>
    </Grid>
</Window>
