<UserControl x:Class="AiTokenBot.Views.WalletPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AiTokenBot.Views"
             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="860">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="钱包" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <TextBlock Text="多钱包管理与资产概览" FontSize="13" Margin="0,4,0,0"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                       Opacity="0.6"/>
        </StackPanel>

        <!-- Wallet Selector Bar -->
        <Border Grid.Row="1" Padding="16" CornerRadius="8" Margin="0,0,0,16"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="当前钱包" FontSize="13" VerticalAlignment="Center" Opacity="0.6"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>

                <ComboBox x:Name="WalletSelector" Grid.Column="1" Margin="12,0,0,0" Width="260"
                          Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                          Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"
                          BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                          SelectedIndex="0"
                          SelectionChanged="OnWalletSelected">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontSize="13" Margin="8,0,0,0"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="2" Content="导入钱包" Width="100" Height="32" FontSize="13"
                        Margin="12,0,0,0" Click="OnImportClick"/>
                <Button Grid.Column="3" Content="删除" Width="60" Height="32" FontSize="13"
                        Margin="8,0,0,0" Click="OnDeleteClick"/>
            </Grid>
        </Border>

        <!-- Wallet Detail -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" x:Name="DetailScroll">
            <StackPanel>
                <!-- Address Card -->
                <Border Padding="20" CornerRadius="8"
                        Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                        BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="钱包地址" FontSize="12" Opacity="0.6"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock x:Name="TbAddress" Text="8xHy2RqG...FjL9mWpQxZ" FontSize="16" FontWeight="SemiBold"
                                       Margin="0,8,0,0" FontFamily="Consolas"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="复制" Width="70" Height="28" FontSize="12" Margin="0,0,8,0"
                                        Click="OnCopyAddress"/>
                                <Button Content="浏览器" Width="70" Height="28" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TbImportType" Text="导入方式" FontSize="12" Opacity="0.6" TextAlignment="Right"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Right">
                                <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TbNetwork" Text="Solana Mainnet" FontSize="13" FontWeight="SemiBold"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Deposit with QR -->
                <Border Margin="0,16,0,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                        BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="充值" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Text="扫描二维码或复制地址转入 SOL 或 SPL 代币" FontSize="12" Opacity="0.5" Margin="0,6,0,16"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- QR Code -->
                            <Border Grid.Column="0" Width="160" Height="160" CornerRadius="6"
                                    Background="White" VerticalAlignment="Top">
                                <Image x:Name="QrImage" Width="148" Height="148"/>
                            </Border>

                            <!-- Address Text -->
                            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                <TextBlock Text="钱包地址" FontSize="12" Opacity="0.5"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <Border Padding="14,10" CornerRadius="6" Margin="0,6,0,0"
                                        Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   x:Name="TbDepositAddress"
                                                   Text="8xHy2RqGcXnBk4pTvWmD9sLfZjE5aN6iYtUwHqKjRmVoPp3QxZyBdFhJl7Mk1AnC"
                                                   FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <Button Grid.Column="1" Content="复制" Width="80" Height="30" FontSize="12"
                                                VerticalAlignment="Center" Margin="12,0,0,0"
                                                Click="OnCopyAddress"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="仅支持 Solana 网络，请勿跨链转入资产" FontSize="11" Opacity="0.35" Margin="0,8,0,0"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Balances -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="20" CornerRadius="8"
                            Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                            BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SOL 余额" FontSize="12" Opacity="0.6"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock Text="12.45" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock Text="≈ $ 1,775.30" FontSize="12" Opacity="0.5" Margin="0,4,0,0"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="20" CornerRadius="8"
                            Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                            BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="USDC 余额" FontSize="12" Opacity="0.6"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock Text="4,210.00" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock Text="≈ $ 4,210.00" FontSize="12" Opacity="0.5" Margin="0,4,0,0"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Padding="20" CornerRadius="8"
                            Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                            BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="其他代币" FontSize="12" Opacity="0.6"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock Text="5 种" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            <TextBlock Text="≈ $ 2,506.02" FontSize="12" Opacity="0.5" Margin="0,4,0,0"
                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Token List -->
                <Border Margin="0,16,0,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                        BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="代币资产" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <ItemsControl>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Margin="0,0,0,4" CornerRadius="4"
                                            Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="32" Height="32" CornerRadius="16" Background="#3A3A3A"/>
                                                <StackPanel Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Token}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="11" Opacity="0.5"
                                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount}" FontSize="13"
                                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ValueUSD}" FontSize="13" TextAlignment="Right"
                                                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsSource>
                                <x:Array Type="{x:Type local:TokenItem}">
                                    <local:TokenItem Token="SOL" Name="Solana" Amount="12.45" ValueUSD="$ 1,775.30"/>
                                    <local:TokenItem Token="USDC" Name="USD Coin" Amount="4,210.00" ValueUSD="$ 4,210.00"/>
                                    <local:TokenItem Token="BONK" Name="Bonk" Amount="2,500,000" ValueUSD="$ 634.50"/>
                                    <local:TokenItem Token="JUP" Name="Jupiter" Amount="1,850.00" ValueUSD="$ 1,458.22"/>
                                    <local:TokenItem Token="RAY" Name="Raydium" Amount="120.00" ValueUSD="$ 413.30"/>
                                </x:Array>
                            </ItemsControl.ItemsSource>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
