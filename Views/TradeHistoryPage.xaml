<UserControl x:Class="AiTokenBot.Views.TradeHistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AiTokenBot.Views"
             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="860">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="交易记录" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <TextBlock Text="所有机器人交易历史明细" FontSize="13" Margin="0,4,0,0"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                       Opacity="0.6"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Padding="16" CornerRadius="8" Margin="0,0,0,16"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="交易对" VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Opacity="0.6"/>
                <ComboBox Width="140" Margin="10,0,16,0"
                          Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                          Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"
                          BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="SOL/USDC"/>
                    <ComboBoxItem Content="BONK/SOL"/>
                    <ComboBoxItem Content="JUP/SOL"/>
                </ComboBox>
                <TextBlock Text="机器人" VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Opacity="0.6"/>
                <ComboBox Width="120" Margin="10,0,16,0"
                          Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                          Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"
                          BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="套利猎手"/>
                    <ComboBoxItem Content="趋势追踪"/>
                    <ComboBoxItem Content="信号侦察"/>
                </ComboBox>
                <TextBlock Text="方向" VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Opacity="0.6"/>
                <ComboBox Width="100" Margin="10,0,0,0"
                          Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                          Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"
                          BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="买入"/>
                    <ComboBoxItem Content="卖出"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Trade Table -->
        <Border Grid.Row="2" CornerRadius="8"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="时间" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Grid.Column="1" Text="机器人" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Grid.Column="2" Text="交易对" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Grid.Column="3" Text="方向" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Grid.Column="4" Text="数量 / 价格" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Grid.Column="5" Text="盈亏" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <TextBlock Grid.Column="6" Text="状态" FontSize="12" Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                    </Grid>
                </Border>

                <!-- Table Body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TradeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,10"
                                        BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Time}" FontSize="13"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Opacity="0.6"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Robot}" FontSize="13"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Pair}" FontSize="13"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Direction}" FontSize="13"
                                                   Foreground="{Binding DirectionColor}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Detail}" FontSize="13"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding PnL}" FontSize="13"
                                                   Foreground="{Binding PnLColor}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Status}" FontSize="13"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Opacity="0.6"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
