<UserControl x:Class="AiTokenBot.Views.RobotManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AiTokenBot.Views"
             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="860">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="机器人管理" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
            <TextBlock Text="启动、配置、监控每个机器人" FontSize="13" Margin="0,4,0,0"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                       Opacity="0.6"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Robot List -->
            <Border Grid.Column="0" CornerRadius="8"
                    Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                    BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,14,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="机器人列表" FontSize="12" Opacity="0.6" VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                        <Button Grid.Column="1" Content="+ 新增" Width="68" Height="28" FontSize="12"
                                Click="OnAddRobot"/>
                    </Grid>

                    <ListBox x:Name="RobotList" Grid.Row="1"
                             BorderThickness="0"
                             SelectionChanged="OnRobotSelected">
                        <ListBox.Resources>
                            <Style TargetType="ListBox">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderThickness="3,0,0,0"
                                                    BorderBrush="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background"
                                                            Value="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"/>
                                                    <Setter TargetName="Border" Property="BorderBrush"
                                                            Value="{DynamicResource {x:Static adonisUi:Brushes.AccentBrush}}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background"
                                                            Value="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding StatusBrush}"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Margin="12,0,0,0"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="20,4,0,0">
                                        <TextBlock Text="{Binding Strategy}" FontSize="11" Opacity="0.5"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="8,0,0,0"
                                                   Foreground="{Binding StatusBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right: Detail Panel -->
            <Grid Grid.Column="2" x:Name="DetailPanel" Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Robot Header -->
                        <Border Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="40" Height="40"
                                         Fill="{Binding StatusBrush}"
                                         VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="10,0,0,0"
                                                   Foreground="{Binding StatusBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Strategy}" FontSize="12" Opacity="0.5" Margin="0,2,0,0"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="编辑" Width="60" Height="30" FontSize="12" Margin="0,0,8,0"
                                        Click="OnEditRobot"/>
                                <Button Grid.Column="3" Content="删除" Width="60" Height="30" FontSize="12"
                                        Click="OnDeleteRobot"/>
                            </Grid>
                        </Border>

                        <!-- Balance & PnL Card -->
                        <Border Margin="0,12,0,0" Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="账户余额" FontSize="12" Opacity="0.6"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Text="{Binding BalanceDisplay}" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="今日盈亏" FontSize="12" Opacity="0.6"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Text="{Binding TodayPnL}" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0"
                                                   Foreground="{Binding PnLBrushes}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="累计盈亏" FontSize="12" Opacity="0.6"
                                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                        <TextBlock Text="{Binding TotalPnL}" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0"
                                                   Foreground="{Binding PnLBrushes}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Transfer + Start/Stop -->
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="转入" Width="80" Height="34" FontSize="13"
                                                Click="OnDepositClick"/>
                                        <Button Content="转出" Width="80" Height="34" FontSize="13" Margin="8,0,0,0"
                                                Click="OnWithdrawClick"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="ToggleBtn"
                                            Content="{Binding ToggleText}" Width="100" Height="34" FontSize="13"
                                            Click="OnToggleRunningClick"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Bot Log -->
                        <Border Margin="0,12,0,0" Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="运行日志" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <TextBox x:Name="TbBotLog" Margin="0,10,0,0" Height="180"
                                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"
                                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Personality -->
                        <Border Margin="0,12,0,0" Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="人格设定" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <TextBlock Text="{Binding Personality}" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Opacity="0.8"/>
                            </StackPanel>
                        </Border>

                        <!-- Strategy -->
                        <Border Margin="0,12,0,0" Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="交易策略" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="最低盈利空间" Opacity="0.6" VerticalAlignment="Center"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MinProfitPercent}"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最大单笔交易量" Opacity="0.6" Margin="0,10,0,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MaxTradeAmount}" Margin="0,10,0,0"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="滑点容忍度" Opacity="0.6" Margin="0,10,0,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SlippagePercent}" Margin="0,10,0,0"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LLM Selection -->
                        <Border Margin="0,12,0,0" Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="驱动大模型" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="选择模型" VerticalAlignment="Center" Opacity="0.6"
                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                    <ComboBox x:Name="CbLlmModel" Grid.Column="1"
                                              Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                              Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}"
                                              BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                                              SelectionChanged="OnLlmModelChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding Name}"/><Run Text=" · " Foreground="Gray"/><Run Text="{Binding PlatformName}" Foreground="Gray"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Positions -->
                        <Border Margin="0,12,0,0" Padding="20" CornerRadius="8"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="当前持仓" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Positions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="0,8" Margin="0,0,0,1"
                                                    BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer2BorderBrush}}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Token}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Amount}" FontSize="13"
                                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding CurrentPrice}" FontSize="13"
                                                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding PnL}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{Binding PnLBrush}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
