<Window x:Class="AiTokenBot.Views.RobotEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="500" Height="560">
    <Window.Style>
        <Style TargetType="Window" BasedOn="{StaticResource {x:Type Window}}"/>
    </Window.Style>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="DialogTitle" Text="新增机器人"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"
                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Name -->
                <TextBlock Text="机器人名称" FontSize="13" Margin="0,0,0,4"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <TextBox x:Name="TbName" Height="36"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>

                <!-- Strategy -->
                <TextBlock Text="交易策略" FontSize="13" Margin="0,16,0,4"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <TextBox x:Name="TbStrategy" Height="36"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>

                <!-- Personality -->
                <TextBlock Text="人格设定" FontSize="13" Margin="0,16,0,4"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <TextBox x:Name="TbPersonality" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>

                <!-- Min Profit -->
                <TextBlock Text="最低盈利空间 (%)" FontSize="13" Margin="0,16,0,4"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <TextBox x:Name="TbMinProfit" Height="36"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>

                <!-- Max Trade -->
                <TextBlock Text="最大单笔交易量" FontSize="13" Margin="0,16,0,4"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <TextBox x:Name="TbMaxTrade" Height="36"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>

                <!-- Slippage -->
                <TextBlock Text="滑点容忍度 (%)" FontSize="13" Margin="0,16,0,4"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <TextBox x:Name="TbSlippage" Height="36"
                         Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                         Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                         BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Width="90" Height="38"
                    Click="OnCancelClick"/>
            <Button Content="保存" Width="90" Height="38" Margin="12,0,0,0"
                    Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
